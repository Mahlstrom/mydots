# Interactive shell-specific configurations

# Zsh options
setopt HIST_FCNTL_LOCK
unsetopt APPEND_HISTORY
setopt HIST_IGNORE_DUPS
unsetopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY

# History settings
HISTSIZE="10000"
SAVEHIST="10000"
HISTFILE="$HOME/.zsh_history"
mkdir -p "$(dirname "$HISTFILE")"

# Initialize completion system
autoload -Uz compinit
compinit

# Load tool-specific configs from .shell/ subdirectory
for dir in $HOME/.config/*(N/); do
  local tool_name=$(basename "$dir")
  local loadable=0

  # Always load: zsh, bash, common (shell builtins / always-present tools)
  if [[ "$tool_name" == "zsh" || "$tool_name" == "bash" || "$tool_name" == "common" ]] || (( $+commands[$tool_name] )); then
    loadable=1
  elif [[ -f "$dir/.commands" ]]; then
    while IFS= read -r cmd; do
      if (( $+commands[$cmd] )); then
        loadable=1
        break
      fi
    done < "$dir/.commands"
  fi

  if (( loadable )); then
    local shell_dir="$dir/.shell"
    [[ -f "$shell_dir/.functions"  ]] && source "$shell_dir/.functions"
    [[ -f "$shell_dir/.alias"      ]] && source "$shell_dir/.alias"
    [[ -f "$shell_dir/.zshrc"      ]] && source "$shell_dir/.zshrc"
    [[ -f "$shell_dir/.completion" ]] && source "$shell_dir/.completion"
  fi
done

# Load per-project bin configs
for file in $HOME/github.com/mahlstrom/*/bin/.zshrc(N); do
  [[ -f "$file" ]] && source "$file"
done
