# zprofile - Sourced for login shells

# Machine identity & Homebrew bundle
MACHINE=$(hostname)
export MACHINE
export HOMEBREW_BUNDLE_FILE="$HOME/.config/homebrew/Brewfile_$MACHINE"

# Load .shell/.zprofile from each tool module
for dir in $HOME/.config/*(N/); do
  [[ -f "$dir/.shell/.zprofile" ]] && source "$dir/.shell/.zprofile"
done
