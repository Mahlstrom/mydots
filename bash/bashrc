# bashrc - Bash Interactive Shell Configuration

# Environment Variables
export CLICOLOR="1"
export EDITOR="nvim"
export NVIM_APPNAME="nvim_files/mahlstrom/nvim-newsbs/"
export NVIM_APPNAME2="nvim_files/mahlstrom/nvim/"
export PAGER="less"

# Path Setup
[[ -f "$HOME/.config/common/path.sh" ]] && source "$HOME/.config/common/path.sh"

# Homebrew Bundle
export HOMEBREW_BUNDLE_FILE="$HOME/.config/homebrew/Brewfile_$MACHINE"

# History Settings
HISTSIZE=10000
HISTFILESIZE=10000
HISTCONTROL=ignoredups:erasedups
HISTFILE="$HOME/.bash_history"
shopt -s histappend

# Load tool-specific configs
for dir in "$HOME"/.config/*/; do
    dir=${dir%/}
    tool_name=$(basename "$dir")
    # Only load if the tool exists (or if it's a generic config folder)
    if [[ "$tool_name" == "zsh" || "$tool_name" == "bash" || "$tool_name" == "common" ]] || command -v "$tool_name" >/dev/null 2>&1; then
        [ -f "$dir/.bashrc" ] && source "$dir/.bashrc"
        [ -f "$dir/alias.sh" ] && source "$dir/alias.sh"
        [ -f "$dir/init.sh" ] && source "$dir/init.sh"
    fi
done

# Load .bashrc from github.com/mahlstrom/*/bin/
for file in "$HOME"/github.com/mahlstrom/*/bin/.bashrc; do
    [ -f "$file" ] && source "$file"
done
