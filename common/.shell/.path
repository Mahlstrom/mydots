# Zsh optimized path management (typeset -U deduplicates automatically)
typeset -U path
path=(
    /opt/homebrew/bin
    /opt/homebrew/sbin
    $HOME/.config/composer/vendor/bin
    $HOME/github.com/mahlstrom/php-bin/bin
    /opt/homebrew/opt/mysql-client/bin
    $HOME/github.com/mahlstrom/argbash
    /Applications/PhpStorm.app/Contents/MacOS
    /usr/local/bin
    /usr/local/sbin
    $path
)
